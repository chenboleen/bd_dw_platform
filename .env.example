# ==========================================
# 环境变量配置示例
# 复制此文件为 .env 并修改对应值
# ==========================================

# MySQL 配置
MYSQL_ROOT_PASSWORD=root123456
MYSQL_DATABASE=metadata_db
MYSQL_USER=metadata_user
MYSQL_PASSWORD=metadata_pass
MYSQL_PORT=3306

# Redis 配置
REDIS_PORT=6379

# Elasticsearch 配置
ES_PORT=9200

# JWT 密钥（生产环境必须修改为强随机字符串）
JWT_SECRET=kiro-metadata-dw-2024-secure-jwt-signing-key-base64-encoded-minimum-256-bits

# 服务端口
BACKEND_PORT=8080
FRONTEND_PORT=80
